# ─────────────────────────────────────────────────────────────
#  IEG Strategic Initiatives — Environment Configuration (template)
#  Copy to .env and fill in. Never commit the real .env (it holds secrets).
# ─────────────────────────────────────────────────────────────

# ── App ──
APP_PORT=8502
APP_HOST=127.0.0.1              # localhost for dev; Azure serves via gunicorn

# ── Local fallback data (used until the live List connection is configured) ──
CSV_PATH=data/Strategic_Initiatives_2026.csv
EDITS_PATH=data/edits.json
SUB_INITIATIVES_PATH=data/sub_initiatives.json

# ── Microsoft Entra SSO (user sign-in) ──
# SSO enforces only when ENTRA_CLIENT_ID is set; locally you can leave these
# blank to run open. Redirect URI must be registered on the Entra app.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8502/auth/callback
SESSION_SECRET=                 # any long random string (Flask session signing)

# ── App-only Microsoft Graph (read/write the SharePoint List as a service) ──
# Site is confirmed. LIST_NAME can stay blank until the probe shows the exact name.
SHAREPOINT_SITE_URL=https://iegna.sharepoint.com/sites/2023IEGStrategicPlan
LIST_NAME=
# Graph app creds. If you reuse the ENTRA_* app for List access too, you only
# need GRAPH_CLIENT_SECRET here (tenant/client fall back to the ENTRA_* values).
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
